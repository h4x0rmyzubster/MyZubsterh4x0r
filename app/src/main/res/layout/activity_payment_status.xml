<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💳 Stato Pagamento"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <!-- Rimuovi l'attributo app:progressColor -->
    <com.myzbuster.app.widgets.PaymentProgressBar
        android:id="@+id/payment_progress_bar"
        android:layout_width="300dp"
        android:layout_height="30dp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/payment_status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏳ In attesa..."
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/payment_amount_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Importo: 0.00 XMR"
        android:textSize="16sp"
        android:textColor="@android:color/darker_gray"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/payment_status_detail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ID Transazione: -"
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/payment_retry_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔄 Riprova"
        android:visibility="gone" />

</LinearLayout>